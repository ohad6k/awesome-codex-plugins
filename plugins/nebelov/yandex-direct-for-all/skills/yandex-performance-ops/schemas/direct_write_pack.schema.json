{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/yandex-direct-for-all/direct-write-pack.schema.json",
  "title": "Подтверждённый пакет записи Яндекс.Директа",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "client_login",
    "environment",
    "operation_type",
    "created_at",
    "expires_at",
    "source_snapshot_sha256",
    "owner_approval_ref",
    "max_api_units",
    "operations"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,79}$"},
    "client_login": {"type": "string", "minLength": 1},
    "environment": {"enum": ["sandbox", "production"]},
    "operation_type": {
      "enum": [
        "campaigns.add", "campaigns.update", "campaigns.suspend",
        "adgroups.add", "adgroups.update",
        "ads.add", "ads.update", "ads.suspend", "ads.resume", "ads.archive", "ads.moderate",
        "keywords.add", "keywords.update", "negativekeywordsharedsets.add"
      ]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "source_snapshot_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "owner_approval_ref": {"type": "string", "minLength": 1},
    "max_api_units": {"type": "integer", "minimum": 1},
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/operation"}
    }
  },
  "$defs": {
    "readback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "version", "params", "result_key"],
      "properties": {
        "service": {"enum": ["campaigns", "adgroups", "ads", "keywords", "negativekeywordsharedsets", "sitelinks", "adextensions", "bids", "keywordbids"]},
        "version": {"enum": ["v5", "v501"]},
        "params": {"type": "object"},
        "result_key": {"type": "string", "minLength": 1}
      }
    },
    "manualDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source", "evidence", "scope", "reviewer", "reviewed_at",
        "expires_at", "decision", "reversal_ref", "source_row_sha256"
      ],
      "properties": {
        "source": {"type": "string", "minLength": 1},
        "evidence": {},
        "scope": {"type": "string", "minLength": 1},
        "reviewer": {"type": "string"},
        "reviewed_at": {"type": "string"},
        "expires_at": {"type": "string"},
        "decision": {"type": "string"},
        "reversal_ref": {"type": "string"},
        "source_row_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "service", "method", "version", "params", "depends_on", "readback", "expected_after", "reversible", "estimated_api_units", "max_api_units"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"},
        "service": {"type": "string"},
        "method": {"type": "string"},
        "version": {"enum": ["v5", "v501"]},
        "params": {"type": "object"},
        "depends_on": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "readback": {"$ref": "#/$defs/readback"},
        "expected_after": {},
        "reversible": {"type": "boolean"},
        "estimated_api_units": {"type": "integer", "minimum": 1},
        "max_api_units": {"type": "integer", "minimum": 1},
        "reversal_fields": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "irreversible_reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
