{
  "mcpServers": {
    "yandexDirect": {
      "command": "uv",
      "args": [
        "run",
        "--frozen",
        "--project",
        "./mcp/yandex-direct",
        "python",
        "./mcp/yandex-direct/server.py",
        "stdio"
      ],
      "env": {
        "YANDEX_DIRECT_ENVIRONMENT": "${YANDEX_DIRECT_ENVIRONMENT}",
        "YANDEX_DIRECT_SANDBOX_TOKEN": "${YANDEX_DIRECT_SANDBOX_TOKEN}",
        "YANDEX_DIRECT_PRODUCTION_READ_TOKEN": "${YANDEX_DIRECT_PRODUCTION_READ_TOKEN}",
        "YANDEX_DIRECT_CLIENT_LOGIN": "${YANDEX_DIRECT_CLIENT_LOGIN}",
        "YANDEX_DIRECT_OUTPUT_DIR": "${YANDEX_DIRECT_OUTPUT_DIR}"
      }
    },
        "yandexSearch": {
            "command": "uv",
            "args": [
                "run",
                "--frozen",
                "--project",
                "./mcp/yandex-search",
                "python",
                "./mcp/yandex-search/server.py"
            ],
      "env": {
        "YANDEX_SEARCH_API_KEY": "${YANDEX_SEARCH_API_KEY}",
        "YANDEX_SEARCH_FOLDER_ID": "${YANDEX_SEARCH_FOLDER_ID}",
        "YANDEX_SEARCH_ROUTE": "${YANDEX_SEARCH_ROUTE}",
        "YANDEX_SEARCH_APPROVAL_FILE": "${YANDEX_SEARCH_APPROVAL_FILE}",
        "YANDEX_SEARCH_USAGE_LEDGER": "${YANDEX_SEARCH_USAGE_LEDGER}"
      }
    },
    "yandexWordstat": {
      "command": "node",
      "args": [
        "./mcp/yandex-wordstat/src/index.mjs"
      ],
      "env": {
        "YANDEX_WORDSTAT_API_KEY": "${YANDEX_WORDSTAT_API_KEY}",
        "YANDEX_WORDSTAT_FOLDER_ID": "${YANDEX_WORDSTAT_FOLDER_ID}",
        "YDFALL_STATE_ROOT": "${YDFALL_STATE_ROOT}"
      }
    }
  }
}
