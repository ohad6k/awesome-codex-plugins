{
  "name": "session-orchestrator",
  "version": "3.12.0",
  "description": "Session Orchestrator — Claude Code plugin for structured development sessions",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "node scripts/check-package-manager.mjs && vitest --run",
    "test:coverage": "node scripts/check-package-manager.mjs && vitest --run --coverage",
    "test:watch": "node scripts/check-package-manager.mjs && vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "node scripts/typecheck.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "share:hw-learnings": "node scripts/export-hw-learnings.mjs",
    "vault-watcher": "node scripts/vault-integration-watcher.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "ajv": "^8.17.1",
    "mdast-util-to-string": "^4.0.0",
    "remark": "^15.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "zx": "^8.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "js-yaml": "^4.2.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.0.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vite": "^8.0.16"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kanevry/session-orchestrator.git"
  },
  "pi": {
    "extensions": [
      "./pi/extensions/session-orchestrator.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./pi/prompts/*.md"
    ]
  }
}
