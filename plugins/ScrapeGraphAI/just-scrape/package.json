{
	"name": "just-scrape",
	"version": "1.1.0",
	"description": "ScrapeGraph AI CLI tool",
	"type": "module",
	"main": "dist/cli.mjs",
	"bin": {
		"just-scrape": "dist/cli.mjs"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "tsup",
		"lint": "biome check .",
		"format": "biome format . --write",
		"test": "bun test",
		"check": "tsc --noEmit && biome check .",
		"prepublishOnly": "tsup"
	},
	"keywords": [
		"cli",
		"scraping",
		"ai",
		"scrapegraph"
	],
	"author": "ScrapeGraph Team",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"chalk": "^5.4.1",
		"citty": "^0.2.2",
		"dotenv": "^17.2.4",
		"scrapegraph-js": "^2.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "^1.3.9",
		"@types/node": "^25.9.2",
		"tsup": "^8.3.6",
		"typescript": "^6.0.3"
	}
}
