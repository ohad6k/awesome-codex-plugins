{
  "name": "@useorgx/codex-plugin",
  "version": "0.1.7",
  "description": "OrgX Codex plugin with MCP access, initiative-aware skills, and a Sovereign Execution peer sidecar.",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useorgx/orgx-codex-plugin.git"
  },
  "homepage": "https://github.com/useorgx/orgx-codex-plugin#readme",
  "bugs": {
    "url": "https://github.com/useorgx/orgx-codex-plugin/issues"
  },
  "bin": {
    "orgx-codex-peer": "lib/peer/cli.mjs",
    "orgx-codex-reconcile-hooks": "hooks/scripts/orgx-work-graph-reconcile.mjs",
    "orgx-codex-diagnose-reporting": "scripts/diagnose-reporting-gates.mjs"
  },
  "exports": {
    ".": "./lib/peer/peer.mjs",
    "./peer": "./lib/peer/peer.mjs"
  },
  "files": [
    ".agents/plugins/marketplace.json",
    ".codex-plugin/",
    ".mcp.json",
    "assets/",
    "hooks/codex/",
    "hooks/scripts/orgx-reconcile-hook.mjs",
    "hooks/scripts/orgx-session-hook.mjs",
    "hooks/scripts/orgx-work-graph-reconcile.mjs",
    "docs/client-hook-coverage.md",
    "docs/operator-reporting-gates.json",
    "lib/peer/cli.mjs",
    "lib/peer/CodexDriver.mjs",
    "lib/peer/peer.mjs",
    "lib/peer/README.md",
    "lib/peer/sentry.mjs",
    "plugin.manifest.json",
    "scripts/diagnose-reporting-gates.mjs",
    "scripts/verify-plugin.mjs",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node scripts/verify-plugin.mjs",
    "test": "node --test lib/peer/peer.test.mjs hooks/scripts/orgx-session-hook.test.mjs hooks/scripts/orgx-reconcile-hook.test.mjs hooks/scripts/orgx-work-graph-reconcile.test.mjs scripts/diagnose-reporting-gates.test.mjs",
    "prepublishOnly": "npm run check && npm test",
    "peer:start": "node lib/peer/cli.mjs"
  },
  "dependencies": {
    "@sentry/node": "10.65.0",
    "@useorgx/orgx-gateway-sdk": "github:useorgx/orgx-gateway-sdk#40871edeb9b92eaf4403c0ba7270a74204ba425f",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
