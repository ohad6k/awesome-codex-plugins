{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/learn-receipt.v1.schema.json",
  "title": "Learn Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase",
    "skill",
    "status",
    "input_verdict_ref",
    "input_verdict_digest",
    "artifact",
    "observations",
    "producer_candidates",
    "remaining_work",
    "plan_impact"
  ],
  "allOf": [
    {
      "if": {
        "properties": {"remaining_work": {"const": false}},
        "required": ["remaining_work"]
      },
      "then": {
        "properties": {
          "plan_impact": {
            "properties": {"disposition": {"const": "terminal"}}
          }
        }
      },
      "else": {
        "properties": {
          "plan_impact": {
            "properties": {
              "disposition": {"enum": ["material_change", "no_change"]}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "plan_impact": {
            "properties": {"disposition": {"const": "material_change"}},
            "required": ["disposition"]
          }
        },
        "required": ["plan_impact"]
      },
      "then": {
        "properties": {
          "plan_impact": {
            "required": ["proposed_changes"],
            "properties": {"proposed_changes": {"minItems": 1}}
          }
        }
      },
      "else": {
        "properties": {
          "plan_impact": {
            "properties": {"proposed_changes": {"maxItems": 0}}
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {"const": "learn-receipt.v1"},
    "phase": {"const": "learn"},
    "skill": {"const": "learn"},
    "status": {"enum": ["DONE", "PARTIAL", "BLOCKED"]},
    "input_verdict_ref": {"type": "string", "minLength": 1},
    "input_verdict_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifact": {"type": "string", "minLength": 1},
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "summary", "evidence_ref", "disposition"],
        "properties": {
          "kind": {"enum": ["finding", "coverage-gap", "strength", "process-signal"]},
          "summary": {"type": "string", "minLength": 1},
          "evidence_ref": {"type": "string", "minLength": 1},
          "disposition": {"enum": ["record", "candidate", "no_change"]},
          "observation_id": {"type": "string", "minLength": 1},
          "class_key": {"type": "string", "minLength": 1},
          "objective_id": {"type": "string", "minLength": 1}
        }
      }
    },
    "producer_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "class_key", "recurrence_count", "advisory", "evidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^producer-[0-9a-f]{12}$"},
          "class_key": {"type": "string", "minLength": 1},
          "summary": {"type": "string"},
          "recurrence_count": {"type": "integer", "minimum": 2},
          "advisory": {"const": true},
          "evidence": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["observation_id", "objective_id", "evidence_ref"],
              "properties": {
                "observation_id": {"type": "string", "minLength": 1},
                "objective_id": {"type": "string", "minLength": 1},
                "evidence_ref": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "remaining_work": {"type": "boolean"},
    "plan_impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "summary", "evidence_refs"],
      "properties": {
        "disposition": {
          "enum": ["material_change", "no_change", "terminal"]
        },
        "summary": {"type": "string", "minLength": 1},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "proposed_changes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "next_action": {"type": "string"}
  }
}
