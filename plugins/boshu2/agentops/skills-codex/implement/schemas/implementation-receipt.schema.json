{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/implementation-receipt.v1.json",
  "title": "Implementation receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "issue_id", "base_sha", "head_sha", "work_class", "acceptance_ids", "changed_files", "red", "green", "independent_validation"],
  "properties": {
    "schema_version": { "const": 1 },
    "issue_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "base_sha": { "$ref": "#/$defs/sha" },
    "head_sha": { "$ref": "#/$defs/sha" },
    "work_class": { "enum": ["behavior", "docs-only", "pure-refactor"] },
    "acceptance_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "changed_files": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/path" } },
    "red": {
      "oneOf": [
        { "$ref": "#/$defs/captured_red" },
        { "$ref": "#/$defs/red_waiver" }
      ]
    },
    "green": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command_evidence" } },
    "behavioral_spec": {
      "oneOf": [
        { "$ref": "#/$defs/evidence" },
        { "type": "object", "additionalProperties": false, "required": ["skipped_reason"], "properties": { "skipped_reason": { "type": "string", "minLength": 1 } } }
      ]
    },
    "independent_validation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["disposition"],
          "properties": { "disposition": { "const": "PENDING" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["disposition", "pr", "source_verdict_path", "copied_verdict", "review_evidence"],
          "properties": {
            "disposition": { "enum": ["CONFIRMED", "REFUTED", "HOLD"] },
            "pr": { "type": "integer", "minimum": 0 },
            "source_verdict_path": { "$ref": "#/$defs/path" },
            "copied_verdict": { "$ref": "#/$defs/evidence" },
            "review_evidence": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/evidence" } }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "work_class": { "const": "behavior" } } },
      "then": { "required": ["behavioral_spec"], "properties": { "red": { "$ref": "#/$defs/captured_red" }, "behavioral_spec": { "$ref": "#/$defs/evidence" } } }
    }
  ],
  "$defs": {
    "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\r\\n]+$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": { "path": { "$ref": "#/$defs/path" }, "sha256": { "$ref": "#/$defs/digest" } }
    },
    "test_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": { "path": { "$ref": "#/$defs/path" }, "sha256": { "$ref": "#/$defs/digest" } }
    },
    "command_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exit_code", "evidence"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "exit_code": { "const": 0 },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "captured_red": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "observed_sha", "command", "exit_code", "evidence", "test_files"],
      "properties": {
        "kind": { "const": "captured" },
        "observed_sha": { "$ref": "#/$defs/sha" },
        "command": { "type": "string", "minLength": 1 },
        "exit_code": { "type": "integer", "minimum": 1, "maximum": 125 },
        "evidence": { "$ref": "#/$defs/evidence" },
        "test_files": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/test_file" } }
      }
    },
    "red_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reason", "evidence"],
      "properties": {
        "kind": { "const": "waived" },
        "reason": { "enum": ["docs-only", "pure-refactor"] },
        "evidence": { "$ref": "#/$defs/evidence" },
        "baseline_before": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command_evidence" } },
        "baseline_after": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command_evidence" } },
        "test_drivers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/test_file" } }
      },
      "allOf": [
        {
          "if": { "properties": { "reason": { "const": "pure-refactor" } } },
          "then": { "required": ["baseline_before", "baseline_after", "test_drivers"] }
        }
      ]
    }
  }
}
