{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/rpi-run-governor.v1.json",
  "title": "Persistent RPI run governor state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "limits",
    "usage",
    "disposition",
    "reason",
    "authorized",
    "admissions",
    "helper",
    "helper_history"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "limits": { "$ref": "#/$defs/limits" },
    "usage": { "$ref": "#/$defs/meters" },
    "disposition": {
      "enum": ["NOTE", "REPAIR", "REPLAN", "HOLD", "ANDON"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "authorized": { "type": "boolean" },
    "admissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sequence", "action", "charge", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sequence": { "type": "integer", "minimum": 1 },
          "action": {
            "enum": ["crank-wave", "semantic-review", "deterministic-proof"]
          },
          "charge": { "$ref": "#/$defs/meters" },
          "status": { "const": "recorded" }
        },
        "allOf": [
          {
            "if": {
              "properties": { "action": { "const": "crank-wave" } },
              "required": ["action"]
            },
            "then": {
              "properties": {
                "charge": {
                  "properties": { "waves": { "const": 1 } },
                  "required": ["waves"]
                }
              }
            },
            "else": {
              "properties": {
                "charge": {
                  "properties": { "waves": { "const": 0 } },
                  "required": ["waves"]
                }
              }
            }
          }
        ]
      }
    },
    "helper": {
      "type": "object",
      "required": ["allowed"],
      "properties": {
        "allowed": { "type": "boolean" },
        "blocker_class": { "type": "string", "minLength": 1 },
        "result": { "enum": ["UNSTUCK", "ESCALATE"] },
        "new_approach": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "helper_history": {
      "type": "object",
      "propertyNames": { "minLength": 1 },
      "additionalProperties": {
        "type": "object",
        "required": ["result"],
        "properties": {
          "result": { "enum": ["UNSTUCK", "ESCALATE"] },
          "new_approach": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": { "result": { "const": "UNSTUCK" } },
              "required": ["result"]
            },
            "then": { "required": ["new_approach"] }
          }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "disposition": { "const": "HOLD" } },
        "required": ["disposition"]
      },
      "then": {
        "properties": {
          "reason": {
            "enum": ["max-attempts", "oscillation", "no-progress"]
          },
          "helper": {
            "properties": { "allowed": { "const": true } },
            "required": ["allowed", "blocker_class"]
          }
        }
      },
      "else": {
        "properties": {
          "helper": {
            "properties": { "allowed": { "const": false } },
            "required": ["allowed"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "authorized": { "const": true } },
        "required": ["authorized"]
      },
      "then": {
        "properties": {
          "disposition": { "const": "NOTE" },
          "reason": { "const": "admitted-before-dispatch" },
          "admissions": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "helper": {
            "properties": { "result": { "const": "UNSTUCK" } },
            "required": ["result"]
          }
        },
        "required": ["helper"]
      },
      "then": {
        "properties": {
          "helper": { "required": ["new_approach", "blocker_class"] },
          "disposition": { "const": "REPAIR" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "helper": {
            "properties": { "result": { "const": "ESCALATE" } },
            "required": ["result"]
          }
        },
        "required": ["helper"]
      },
      "then": {
        "properties": {
          "helper": { "required": ["blocker_class"] },
          "disposition": { "const": "ANDON" }
        }
      }
    }
  ],
  "$defs": {
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waves",
        "reviewer_tokens",
        "elapsed_seconds",
        "review_contexts",
        "deterministic_executions"
      ],
      "properties": {
        "waves": { "type": "integer", "minimum": 1 },
        "reviewer_tokens": { "type": "integer", "minimum": 1 },
        "elapsed_seconds": { "type": "integer", "minimum": 1 },
        "review_contexts": { "type": "integer", "minimum": 1 },
        "deterministic_executions": { "type": "integer", "minimum": 1 }
      }
    },
    "meters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "waves",
        "reviewer_tokens",
        "elapsed_seconds",
        "review_contexts",
        "deterministic_executions"
      ],
      "properties": {
        "waves": { "type": "integer", "minimum": 0 },
        "reviewer_tokens": { "type": "integer", "minimum": 0 },
        "elapsed_seconds": { "type": "integer", "minimum": 0 },
        "review_contexts": { "type": "integer", "minimum": 0 },
        "deterministic_executions": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
