{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops.dev/schemas/rpi-run-disposition.v1.json",
  "title": "Immutable RPI run disposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "objective",
    "disposition",
    "reason",
    "evidence_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "digest"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "disposition": {
      "enum": ["NOTE", "REPAIR", "REPLAN", "HOLD", "ANDON"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceRef" }
    },
    "blocker_class": { "type": "string", "minLength": 1 },
    "recorded_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
