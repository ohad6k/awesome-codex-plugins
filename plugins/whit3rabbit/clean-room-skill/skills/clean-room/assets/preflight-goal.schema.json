{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clean-Room Preflight Goal Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_id",
    "created_at",
    "end_goal",
    "target_stack",
    "license_policy",
    "dependency_policy",
    "compatibility_policy",
    "feature_policy",
    "code_hygiene_policy",
    "output_policy",
    "controller_policy",
    "open_questions"
  ],
  "properties": {
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "intent_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confirmed_at",
        "end_goal_source",
        "target_stack_source",
        "controller_mode_source",
        "user_goal_summary",
        "user_target_stack_summary"
      ],
      "properties": {
        "confirmed_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_goal_source": {
          "const": "explicit-user-answer"
        },
        "target_stack_source": {
          "const": "explicit-user-answer"
        },
        "controller_mode_source": {
          "const": "explicit-user-answer"
        },
        "user_goal_summary": {
          "type": "string",
          "minLength": 1
        },
        "user_target_stack_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "end_goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "success_definition",
        "destination_kind",
        "existing_destination_policy"
      ],
      "properties": {
        "intent": {
          "enum": [
            "clean-room-reimplementation",
            "behavior-compatible-port",
            "api-compatible-clone",
            "modernization",
            "partial-feature-extraction",
            "test-spec-generation-only",
            "other"
          ]
        },
        "success_definition": {
          "type": "string",
          "minLength": 1
        },
        "destination_kind": {
          "enum": [
            "new-project",
            "existing-project",
            "existing-module",
            "spec-only",
            "other"
          ]
        },
        "existing_destination_policy": {
          "enum": [
            "inspect-and-preserve",
            "create-new",
            "replace-with-confirmation",
            "do-not-inspect",
            "other"
          ]
        }
      }
    },
    "target_stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "runtime",
        "framework",
        "package_manager",
        "test_framework"
      ],
      "properties": {
        "language": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "type": [
            "string",
            "null"
          ]
        },
        "framework": {
          "type": [
            "string",
            "null"
          ]
        },
        "package_manager": {
          "type": [
            "string",
            "null"
          ]
        },
        "test_framework": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "license_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_license_notes",
        "destination_license",
        "dependency_license_allowlist",
        "dependency_license_blocklist"
      ],
      "properties": {
        "source_license_notes": {
          "type": "string"
        },
        "destination_license": {
          "type": "string",
          "minLength": 1
        },
        "dependency_license_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependency_license_blocklist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependency_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_new_dependencies",
        "prefer_stdlib",
        "require_user_approval_for_native_deps",
        "blocked_dependencies"
      ],
      "properties": {
        "allow_new_dependencies": {
          "type": "boolean"
        },
        "prefer_stdlib": {
          "type": "boolean"
        },
        "require_user_approval_for_native_deps": {
          "type": "boolean"
        },
        "blocked_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "compatibility_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mirror_public_behavior",
        "mirror_public_api_names",
        "mirror_private_structure",
        "mirror_comments_or_internal_names",
        "allowed_exactness"
      ],
      "properties": {
        "mirror_public_behavior": {
          "type": "boolean"
        },
        "mirror_public_api_names": {
          "type": "boolean"
        },
        "mirror_private_structure": {
          "const": false
        },
        "mirror_comments_or_internal_names": {
          "const": false
        },
        "allowed_exactness": {
          "type": "array",
          "items": {
            "enum": [
              "public API names",
              "CLI flags",
              "serialized outputs",
              "documented protocol behavior",
              "public error codes",
              "UI behavior",
              "config files",
              "nothing exact, behavior only"
            ]
          }
        }
      }
    },
    "feature_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve_features",
        "remove_features",
        "add_features",
        "non_goals"
      ],
      "properties": {
        "preserve_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "remove_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "add_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "code_hygiene_policy": {
      "$ref": "#/$defs/code_hygiene_policy"
    },
    "output_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_base_root",
        "implementation_root",
        "assumed_output_directory",
        "write_mode"
      ],
      "properties": {
        "artifact_base_root": {
          "type": "string",
          "minLength": 1
        },
        "implementation_root": {
          "type": "string",
          "minLength": 1
        },
        "assumed_output_directory": {
          "type": "string",
          "minLength": 1
        },
        "write_mode": {
          "enum": [
            "create-or-preserve-existing",
            "create-only",
            "preserve-existing",
            "replace-with-confirmation"
          ]
        }
      }
    },
    "execution_policy": {
      "$ref": "#/$defs/execution_policy"
    },
    "controller_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "unattended_allowed_after_preflight",
        "max_iterations"
      ],
      "properties": {
        "mode": {
          "enum": [
            "attended",
            "unattended"
          ]
        },
        "unattended_allowed_after_preflight": {
          "type": "boolean"
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question_id",
          "question",
          "blocking"
        ],
        "properties": {
          "question_id": {
            "type": "string",
            "minLength": 1
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "blocking": {
            "type": "boolean"
          },
          "default_assumption": {
            "type": "string"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "controller_policy": {
            "properties": {
              "mode": {
                "const": "unattended"
              }
            },
            "required": [
              "mode"
            ]
          }
        },
        "required": [
          "controller_policy"
        ]
      },
      "then": {
        "required": [
          "intent_confirmation"
        ],
        "properties": {
          "controller_policy": {
            "properties": {
              "unattended_allowed_after_preflight": {
                "const": true
              }
            },
            "required": [
              "unattended_allowed_after_preflight",
              "max_iterations"
            ]
          },
          "open_questions": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "preferred_container_profile",
        "network_policy",
        "dependency_install_policy",
        "allow_native_toolchain",
        "resource_limits"
      ],
      "properties": {
        "backend": {
          "enum": [
            "host",
            "docker",
            "podman"
          ]
        },
        "preferred_container_profile": {
          "enum": [
            "node22",
            "python312",
            "go126",
            "rust-stable"
          ]
        },
        "network_policy": {
          "enum": [
            "off",
            "deps-only",
            "on"
          ]
        },
        "dependency_install_policy": {
          "enum": [
            "offline",
            "locked",
            "allow-new"
          ]
        },
        "allow_native_toolchain": {
          "type": "boolean"
        },
        "resource_limits": {
          "$ref": "#/$defs/resource_limits"
        }
      }
    },
    "resource_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpus",
        "memory_mb",
        "timeout_seconds"
      ],
      "properties": {
        "cpus": {
          "type": "number",
          "minimum": 1,
          "maximum": 16
        },
        "memory_mb": {
          "type": "integer",
          "minimum": 128,
          "maximum": 65536
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600
        }
      }
    },
    "code_hygiene_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_lines_per_code_file",
        "max_lines_per_test_file",
        "max_files_per_iteration",
        "split_large_files_by",
        "exceptions"
      ],
      "properties": {
        "max_lines_per_code_file": {
          "type": "integer",
          "minimum": 1
        },
        "max_lines_per_test_file": {
          "type": "integer",
          "minimum": 1
        },
        "max_files_per_iteration": {
          "type": "integer",
          "minimum": 1
        },
        "split_large_files_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
