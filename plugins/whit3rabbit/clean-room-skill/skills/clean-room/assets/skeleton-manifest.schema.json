{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clean-Room Skeleton Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "target_language",
    "area_id_naming_policy",
    "architecture_summary",
    "areas",
    "public_contracts",
    "dependency_constraints",
    "implementation_forbidden_material",
    "test_mapping",
    "test_obligations",
    "refactor_triggers",
    "open_decisions"
  ],
  "properties": {
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "target_language": {
      "type": "string",
      "minLength": 1,
      "default": "unspecified"
    },
    "area_id_naming_policy": {
      "type": "string",
      "minLength": 1
    },
    "architecture_summary": {
      "type": "string",
      "minLength": 1
    },
    "target_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "area_id",
          "purpose",
          "owned_path_prefixes",
          "responsibilities",
          "forbidden_responsibilities",
          "allowed_area_dependencies",
          "spec_ids",
          "public_contract_refs",
          "test_obligations"
        ],
        "properties": {
          "area_id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "owned_path_prefixes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/relative_path"
            }
          },
          "responsibilities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_responsibilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowed_area_dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "spec_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "public_contract_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependency_constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_obligations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "open_decisions": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/open_decision"
            }
          }
        }
      }
    },
    "public_contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contract_id",
          "source_spec_id",
          "name",
          "kind",
          "visibility",
          "compatibility_reason"
        ],
        "properties": {
          "contract_id": {
            "type": "string",
            "minLength": 1
          },
          "source_spec_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "visibility": {
            "enum": [
              "public",
              "destination",
              "protocol",
              "user-required"
            ]
          },
          "compatibility_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependency_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_forbidden_material": {
      "type": "array",
      "items": {
        "enum": [
          "source_excerpt",
          "raw_diff",
          "private_identifier",
          "source_shaped_pseudocode",
          "copied_comments",
          "decompiled_output",
          "other"
        ]
      }
    },
    "test_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "test_id",
          "spec_ids",
          "scenario_refs"
        ],
        "properties": {
          "test_id": {
            "type": "string",
            "minLength": 1
          },
          "spec_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scenario_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "test_obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refactor_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_decision"
      }
    }
  },
  "$defs": {
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!~)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "open_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "summary",
        "status",
        "owner"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "open",
            "resolved",
            "deferred"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
