# Keep local artifacts and secrets out of the packaged plugin.
node_modules/
*.vsix
*.log
*.tmp
__pycache__/
*.pyc

# Secrets / credentials — never ship.
.env
.env.*
*.pem
*.key
*.p12
marketplace.env

# OS cruft
.DS_Store

# Non-runtime bulk — the Codex plugin only needs plugin.json, assets/icon.svg,
# .mcp.json and skills/. Everything below is generated site output, datasets,
# promo material, or build tooling that would otherwise balloon the package
# (docs/ alone is ~146MB). Keep these out of the published plugin.
docs/
pitch/
hf-dataset/
.indexnow/
.vercel/
tools/
assets/*.png
CHANGELOG.md
LAUNCH.md
LAUNCH-READY.md
IDEAS.md
DESIGN.md
